# Minimal first-run configuration.
# Run `python3 scripts/setup.py` to create a private .env file. The setup assistant replaces
# the three required values without printing them.

# Required private values
RAG_API_KEY=change-me-generate-a-long-random-value
RAG_QDRANT_API_KEY=change-me-generate-a-different-long-random-value
RAG_OPENAI_API_KEY=

# Optional: only needed when RAG_EMBEDDING_PROVIDER=voyage. OpenAI is still required for answers.
RAG_VOYAGE_API_KEY=

# Default embedding profile. Changing this profile requires a deliberate collection migration.
RAG_EMBEDDING_PROVIDER=openai
RAG_EMBEDDING_MODEL=text-embedding-3-large
RAG_EMBEDDING_DIMENSIONS=3072

# Optional host-loopback port overrides
RAG_API_PORT=8000
RAG_UI_PORT=8501
RAG_QDRANT_HOST_PORT=6333
