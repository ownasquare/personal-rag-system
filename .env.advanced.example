# Advanced Personal Library configuration reference.
# Start with `.env.example` and copy only the overrides you understand into the private `.env`.
# Never commit a populated environment file.

# Application and local endpoints
RAG_ENVIRONMENT=development
RAG_HOST=127.0.0.1
RAG_API_PORT=8000
RAG_UI_PORT=8501
RAG_API_URL=http://127.0.0.1:8000

# Authentication and browser access
RAG_AUTH_ENABLED=true
RAG_API_KEY=change-me-generate-a-long-random-value
RAG_CORS_ORIGINS=["http://127.0.0.1:8501","http://localhost:8501"]

# Local application storage
RAG_DATA_DIR=.data

# Qdrant connection and host-loopback mapping
RAG_QDRANT_MODE=http
RAG_QDRANT_HOST=127.0.0.1
RAG_QDRANT_PORT=6333
RAG_QDRANT_HOST_PORT=6333
RAG_QDRANT_HTTPS=false
RAG_QDRANT_API_KEY=change-me-generate-a-different-long-random-value
RAG_QDRANT_COLLECTION=personal_knowledge

# Provider configuration
# OpenAI is always the answer provider. Voyage can optionally provide embeddings.
RAG_OPENAI_API_KEY=
RAG_VOYAGE_API_KEY=
RAG_EMBEDDING_PROVIDER=openai
RAG_EMBEDDING_MODEL=text-embedding-3-large
RAG_EMBEDDING_DIMENSIONS=3072
RAG_CHAT_PROVIDER=openai
RAG_CHAT_MODEL=gpt-4.1-mini
RAG_CHAT_TEMPERATURE=0.1

# Immutable ingestion profile
# Changing provider, model, dimensions, parser, chunk size, or overlap requires a new collection
# and a deliberate document reindex.
RAG_CHUNK_SIZE=768
RAG_CHUNK_OVERLAP=96
RAG_PARSER_VERSION=1

# Upload and parsing limits (bytes, pages, or extracted characters)
RAG_UPLOAD_MAX_BYTES=26214400
RAG_UPLOAD_READ_BYTES=1048576
RAG_MAX_PDF_PAGES=500
RAG_MAX_EXTRACTED_CHARACTERS=2000000

# Retrieval and conversation limits
RAG_RETRIEVAL_TOP_K=5
RAG_RETRIEVAL_MAX_TOP_K=10
RAG_RETRIEVAL_MIN_SCORE=0.1
RAG_MAX_QUERY_CHARACTERS=4000
RAG_MAX_HISTORY_MESSAGES=12
RAG_CITATION_SNIPPET_CHARACTERS=420

# Durable-job and provider reliability (attempt counts and seconds)
RAG_JOB_MAX_ATTEMPTS=3
RAG_JOB_LEASE_SECONDS=300
RAG_WORKER_POLL_SECONDS=1.0
RAG_WORKER_STALE_SECONDS=90
RAG_PROVIDER_TIMEOUT_SECONDS=60.0
RAG_PROVIDER_MAX_RETRIES=3

# UI refresh behavior (seconds)
RAG_UI_POLL_SECONDS=1.0
RAG_UI_POLL_TIMEOUT_SECONDS=180.0

# Logging and metrics
RAG_LOG_LEVEL=INFO
RAG_JSON_LOGS=true
RAG_METRICS_ENABLED=true
